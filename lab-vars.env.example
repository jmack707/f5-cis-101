# ============================================================================
# lab-vars.env.example — copy to lab-vars.env and fill in for YOUR network:
#     cp lab-vars.env.example lab-vars.env
# The real lab-vars.env is .gitignored (it holds your BIG-IP password).
# Manifests are templated with ${THESE}; scripts render them with envsubst.
# ============================================================================

# ---- BIG-IP ----
BIGIP_MGMT=10.1.1.5
BIGIP_USER=admin
BIGIP_PASS='CHANGE_ME'          # do NOT commit a real password
BIGIP_PARTITION=kubernetes

# ---- CIS controller ----
# Pin to a tag you've verified/mirrored. Docker Hub CIS tags have no 'v' prefix.
CIS_IMAGE=f5networks/k8s-bigip-ctlr:2.20.0
CIS_NAMESPACE=kube-system

# ---- Cluster CNI (modules 2 & 4, cluster mode + static routes) ----
# Must match the CNI your Kubernetes cluster actually runs so CIS reads the pod
# CIDR / node IP from the right node fields. Valid CIS values: flannel,
# calico-k8s, cilium-k8s, antrea, ovn-k8s. The UDF lab cluster is flannel.
# NOTE: Calico also needs the CIS service account granted read on
# 'blockaffinities' (see module2-clusterip/README.md). OVN-Kubernetes uses a
# different routing model than the static routes these labs program.
ORCHESTRATION_CNI=flannel

# ---- Virtual server addresses (per module) — must be free, routable VIPs ----
NODEPORT_VIP=10.1.1.4
CLUSTER_VIP=10.1.10.101
NGINX_FRONT_VIP=10.1.10.101
INGRESSLINK_VIP=10.1.1.4

# ---- AS3 ----
AS3_SCHEMA_VERSION=3.50.0        # set <= the AS3 build installed on the BIG-IP
AS3_TENANT=AS3                   # AS3 tenant = BIG-IP partition the AS3 labs create; keep DISTINCT from BIGIP_PARTITION
